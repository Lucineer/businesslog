# =============================================================================
# Businesslog.ai — Environment Configuration
# Copy this file to .env and fill in the values before running.
# =============================================================================

# --- Application ---
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# --- Authentication ---
# A strong random string (auto-generated by setup.sh if using Docker)
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
# Token expiry (e.g. 1h, 7d, 30d)
JWT_EXPIRY=7d

# --- Initial Admin ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# --- Database ---
# SQLite path (inside container or local path)
DATABASE_URL=file:./data/businesslog.db

# --- Redis (optional, for caching and rate limiting) ---
# Leave empty to disable Redis
REDIS_URL=redis://redis:6379

# --- LLM Integration ---
# API key for the LLM provider (e.g. DeepSeek, OpenAI, Anthropic)
LLM_API_KEY=
# Model identifier (e.g. deepseek-chat, gpt-4o, claude-sonnet-4-20250514)
LLM_MODEL=deepseek-chat
# Base URL for the LLM API (leave empty for provider defaults)
LLM_BASE_URL=https://api.deepseek.com/v1

# --- Logging ---
# One of: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# --- CORS ---
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Rate Limiting ---
# Maximum requests per window per IP
RATE_LIMIT_MAX=100
# Window duration in milliseconds
RATE_LIMIT_WINDOW=60000

# --- Analytics ---
# Enable or disable usage analytics collection
ANALYTICS_ENABLED=true

# --- Backups ---
# Cron schedule for automatic database backups (default: daily at 2 AM)
BACKUP_SCHEDULE=0 2 * * *
